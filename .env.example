WORKER_EVENT_HEARTBEAT_INTERVAL_SECONDS=60
WORKER_MAX_ATTEMPTS=3

JWT_SECRET=deepdive-dev-secret

TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_ALLOWED_HOSTNAMES=localhost,127.0.0.1
