MINIO_SECRET_KEY=deepdive-secret
MINIO_ROOT_USER=deepdive
MINIO_ROOT_PASSWORD=deepdive-secret
MINIO_BUCKET=deepdive-objects
MINIO_SECURE=false

OUTBOX_BATCH_SIZE=100
OUTBOX_RUN_FOREVER=true
OUTBOX_WORKER_RUN_FOREVER=true
OUTBOX_IDLE_SLEEP_SECONDS=1
OUTBOX_ERROR_BACKOFF_SECONDS=5
ANALYSIS_WORKER_GROUP=deepdive-analysis-worker
ANALYSIS_WORKER_MAX_MESSAGES=1
ANALYSIS_WORKER_RUN_FOREVER=true
ANALYSIS_WORKER_IDLE_SLEEP_SECONDS=1
ANALYSIS_WORKER_ERROR_BACKOFF_SECONDS=5
ANALYSIS_WORKER_MAX_ATTEMPTS=3
ANALYSIS_WORKER_EVENT_HEARTBEAT_INTERVAL_SECONDS=60
ANALYSIS_BATCH_SCHEDULER_WORKER_GROUP=deepdive-analysis-batch-scheduler-worker
ANALYSIS_BATCH_SCHEDULER_WORKER_MAX_MESSAGES=1
ANALYSIS_BATCH_SCHEDULER_WORKER_RUN_FOREVER=true
ANALYSIS_BATCH_SCHEDULER_WORKER_IDLE_SLEEP_SECONDS=1
ANALYSIS_BATCH_SCHEDULER_WORKER_ERROR_BACKOFF_SECONDS=5
ANALYSIS_BATCH_SCHEDULER_WORKER_MAX_ATTEMPTS=3
ANALYSIS_BATCH_SCHEDULER_WORKER_EVENT_HEARTBEAT_INTERVAL_SECONDS=60
SNAPSHOT_WORKER_GROUP=deepdive-snapshot-worker
SNAPSHOT_WORKER_MAX_MESSAGES=1
SNAPSHOT_WORKER_RUN_FOREVER=true
SNAPSHOT_WORKER_IDLE_SLEEP_SECONDS=1
SNAPSHOT_WORKER_ERROR_BACKOFF_SECONDS=5
SNAPSHOT_WORKER_MAX_ATTEMPTS=3
SNAPSHOT_WORKER_EVENT_HEARTBEAT_INTERVAL_SECONDS=60
SNAPSHOT_GIT_TIMEOUT_SECONDS=300
SNAPSHOT_MAX_FILE_BYTES=1048576
SNAPSHOT_MAX_GIT_BUNDLE_BYTES=536870912
SNAPSHOT_LFS_POLICY=pointer_only
SNAPSHOT_SUBMODULE_POLICY=record_only
SNAPSHOT_BINARY_POLICY=metadata_only
EXECUTION_WORKER_GROUP=deepdive-execution-worker
EXECUTION_WORKER_MAX_MESSAGES=1
EXECUTION_WORKER_RUN_FOREVER=true
EXECUTION_WORKER_IDLE_SLEEP_SECONDS=1
EXECUTION_WORKER_ERROR_BACKOFF_SECONDS=5
EXECUTION_WORKER_MAX_ATTEMPTS=3
EXECUTION_WORKER_EVENT_HEARTBEAT_INTERVAL_SECONDS=60
EXECUTION_TOOL_HEARTBEAT_INTERVAL_SECONDS=60
AGENT_WORKER_GROUP=deepdive-agent-worker
AGENT_WORKER_MAX_MESSAGES=1
AGENT_WORKER_RUN_FOREVER=true
AGENT_WORKER_IDLE_SLEEP_SECONDS=1
AGENT_WORKER_ERROR_BACKOFF_SECONDS=5
