OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_USER_AGENT=DeepDive/1.0
OPENAI_TIMEOUT_SECONDS=300
OPENAI_TOTAL_TIMEOUT_SECONDS=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
OPENAI_REASONING_SUMMARY=auto
OPENAI_SERVICE_TIER=fast
OPENAI_PARALLEL_TOOL_CALLS=false
# Request transport: http or websocket_v2.
# previous_response_id is controlled separately by OPENAI_USE_PREVIOUS_RESPONSE_ID.
OPENAI_TRANSPORT=http
OPENAI_USE_PREVIOUS_RESPONSE_ID=false
API_SHOW_MODEL_REASONING_SUMMARY=true

PROMPT_SYSTEM_INSTRUCTION_FILE=prompts/system.md
PROMPT_DEVELOPER_INSTRUCTION_FILE=prompts/developer.md
PROMPT_COMPACTION_INSTRUCTION_FILE=prompts/compact.md
PROMPT_SYSTEM_INSTRUCTION=
PROMPT_DEVELOPER_INSTRUCTION=
PROMPT_COMPACTION_INSTRUCTION=

ANALYSIS_DEFAULT_PROFILE=repository_architecture_review
ANALYSIS_GOAL_FILE=profiles/repository_architecture_review.md
ANALYSIS_GOAL=
ANALYSIS_MAX_TURNS=80
ANALYSIS_MAX_TOOL_CALLS=200
ANALYSIS_AUTO_COMPACT_THRESHOLD_TOKENS=120000

# Add web_search and document_* here when those model tools should be exposed.
# Example:
# TOOLS_ENABLED=list_files,search_file,search_text,read_file,web_search,document_create,document_get,document_update,document_delete,document_finalize,document_folder_create
TOOLS_ENABLED=list_files,search_file,search_text,read_file,web_search,document_create,document_get,document_update,document_delete,document_finalize,document_folder_create
TOOL_READ_FILE_DEFAULT_LINES=200
TOOL_READ_FILE_MAX_LINES=500
TOOL_READ_FILE_MAX_BYTES=65536
TOOL_SEARCH_TEXT_MAX_RESULTS=100
TOOL_SEARCH_TEXT_TIMEOUT_SECONDS=20
TOOL_SEARCH_TEXT_MAX_OUTPUT_BYTES=1048576

# Tavily-backed function tool: web_search.
# TOOL_WEB_SEARCH_MAX_RESULTS must be between 1 and 10.
# WEB_SEARCH_TOOL_CHOICE controls how strongly the Responses request nudges search usage:
# auto lets the model decide; required requires at least one tool call when any search tool is available;
# required_tavily forces the Tavily-backed function tool named web_search when it is enabled.
WEB_SEARCH_TOOL_CHOICE=auto
TAVILY_API_KEY=
TOOL_WEB_SEARCH_MAX_RESULTS=10
TOOL_WEB_SEARCH_TIMEOUT_SECONDS=20
TOOL_WEB_SEARCH_MAX_QUERY_CHARS=500

# OpenAI hosted web_search tool. This is separate from the Tavily-backed
# function tool above and is sent to the Responses API as a hosted tool.
OPENAI_WEB_SEARCH_ENABLED=false
OPENAI_WEB_SEARCH_CONTEXT_SIZE=medium
OPENAI_WEB_SEARCH_EXTERNAL_WEB_ACCESS=true
OPENAI_WEB_SEARCH_INCLUDE_SOURCES=false
OPENAI_WEB_SEARCH_ALLOWED_DOMAINS=
OPENAI_WEB_SEARCH_BLOCKED_DOMAINS=
OPENAI_WEB_SEARCH_RETURN_TOKEN_BUDGET=

CACHE_ROOT_DIR=/cache/deepdive
CACHE_MAX_WORKER_CACHE_BYTES=53687091200
CACHE_MAX_PREFIX_BYTES=2147483648
CACHE_TTL_DAYS=7
CACHE_MIN_FREE_DISK_PERCENT=15
